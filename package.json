{
  "name": "unified-log-tree",
  "version": "1.1.5",
  "description": "Unified plugin to log abstract syntax trees (ASTs) without mutating.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc --build tsconfig.build.json && type-coverage",
    "format": "npm run prettier && npm run lint",
    "prettier": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mdast": "vitest run test.mdast.spec.ts",
    "test:hast": "vitest run test.hast.spec.ts",
    "test:esast": "vitest run test.esast.spec.ts",
    "test-coverage": "vitest run --coverage",
    "prepack": "npm run build",
    "prepublishOnly": "npm run format && npm run test-coverage"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ipikuka/unified-log-tree.git"
  },
  "keywords": [
    "unified",
    "abstract syntax tree",
    "AST",
    "mdast",
    "hast",
    "esast",
    "remark",
    "rehype",
    "recma",
    "unified plugin",
    "remark plugin",
    "rehype plugin",
    "recma plugin",
    "unified log tree",
    "unified debug tree",
    "unified inspect tree"
  ],
  "author": "ipikuka <talatkuyuk@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ipikuka/unified-log-tree#readme",
  "bugs": {
    "url": "https://github.com/ipikuka/unified-log-tree/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "dedent": "^1.7.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "unified": "^11.0.5",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@types/unist": "^3.0.3",
    "unist-util-is": "^6.0.1"
  },
  "peerDependencies": {
    "unified": "^11"
  },
  "sideEffects": false,
  "typeCoverage": {
    "atLeast": 100,
    "detail": true,
    "ignoreAsAssertion": true,
    "ignoreCatch": true,
    "strict": true,
    "ignoreFiles": [
      "tests/*.spec.ts"
    ]
  }
}
